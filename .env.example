# NoSpaceFGK Discord Bot Environment Configuration Example

# The secret token of your Discord bot application (REQUIRED)
DISCORD_TOKEN=your_discord_bot_token_here

# The Discord Application/Client ID (REQUIRED)
CLIENT_ID=your_client_id_here

# Prefix for prefix-based commands (Default: !)
BOT_PREFIX=!

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (Default: INFO)
LOG_LEVEL=INFO

# Comma-separated list of Discord User IDs who are bot owners (REQUIRED)
# Example: 123456789012345678,987654321098765432
OWNER_IDS=

# Discord Guild (Server) ID for fast synchronization of slash commands in development (OPTIONAL)
DEVELOPMENT_GUILD_ID=
